{% extends 'base.html.twig' %}

{% block title %}Profile{% endblock %}

{% block body %}
    <main class="container py-4">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-md-row align-items-center gap-4">
                            <div class="position-relative">
                                {% set avatarUrlValue = targetUser and targetUser.avatarUrl ? targetUser.avatarUrl|trim : '' %}
                                {% set avatarSrc = avatarUrlValue ? '/storage/imgs/' ~ avatarUrlValue|url_encode : '' %}
                                {% set showAvatarImage = avatarSrc != '' %}
                                {% set initial = targetUser ? targetUser.username|slice(0,1)|upper : 'U' %}
                                {% if showAvatarImage %}
                                    <img id="profileAvatarImage" src="{{ avatarSrc }}" alt="Profile avatar" class="rounded-circle border" style="width: 96px; height: 96px; object-fit: cover;" onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');">
                                {% endif %}
                                <div id="profileAvatarFallback" class="rounded-circle border text-white d-flex align-items-center justify-content-center {{ showAvatarImage ? 'd-none' : '' }}" style="width: 96px; height: 96px; font-size: 2rem; background: linear-gradient(135deg, #385163ff, #001b2eff);">{{ initial }}</div>
                                {% if targetUser %}
                                    <form id="avatarUploadForm" method="post" action="" enctype="multipart/form-data" class="position-absolute top-0 start-0 w-100 h-100">
                                        <input type="hidden" name="target_user_id" value="{{ targetUser.id }}">
                                        <label for="avatar_file_top" class="w-100 h-100 d-flex align-items-end justify-content-center text-white" style="cursor:pointer;">
                                            <span class="badge text-bg-dark mb-1" style="opacity:0.9;">Change</span>
                                        </label>
                                        <input type="file" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" id="avatar_file_top" name="avatar_file" accept="image/png,image/jpeg,image/jpg,image/gif,image/webp">
                                    </form>
                                {% endif %}
                            </div>
                            <div class="text-center text-md-start">
                                <h2 id="profileDisplayUsername" class="h4 mb-1">{{ targetUser ? targetUser.username : 'Guest' }}</h2>
                                <div id="profileDisplayEmail" class="text-secondary mb-2">{{ targetUser ? targetUser.email : 'Please log in to manage your profile.' }}</div>
                                {% if targetUser %}
                                    <span id="profileRoleBadge" class="badge text-bg-primary me-2">Role: {{ targetUser.isAdmin ? 'Admin' : 'User' }}</span>
                                    <span id="profileRatingBadge" class="badge text-bg-light">Rating: {{ targetUser.rating }}</span>
                                    {% if actorUser and actorUser.id != targetUser.id and actorUser.admin %}
                                        <span class="badge text-bg-warning ms-2">Admin managing this account</span>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

                <div id="profileMessage" class="alert d-none" role="alert"></div>

                {% if not targetUser %}
                    <div class="alert alert-warning" role="alert">You need to log in to access and update your profile.</div>
                {% else %}
                                    {% set isAdminViewer = actorUser and actorUser.isAdmin %}
                    {% set isManagingOtherUser = isAdminViewer and actorUser.id != targetUser.id %}
                    {% set requireCurrentPassword = not isManagingOtherUser %}
                    <div class="row g-4">
                        <div class="col-12 col-lg-8">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-body p-4">
                                    <h3 class="h5 mb-3">Profile Details</h3>
                                    <form id="profileDetailsForm" method="post" action="">
                                        <input type="hidden" name="target_user_id" value="{{ targetUser.id }}">
                                        <div class="row g-3">
                                            <div class="col-12 col-md-6">
                                                <label for="username" class="form-label">Username</label>
                                                <input type="text" class="form-control" id="username" name="username" maxlength="30" required value="{{ targetUser.username }}">
                                            </div>
                                            <div class="col-12 col-md-6">
                                                <label for="email" class="form-label">Email</label>
                                                <input type="email" class="form-control" id="email" name="email" maxlength="150" required value="{{ targetUser.email }}">
                                            </div>
                                            <div class="col-12">
                                                <label for="bio" class="form-label">Bio</label>
                                                <textarea class="form-control" id="bio" name="bio" rows="4" placeholder="Tell people about yourself">{{ targetUser.bio }}</textarea>
                                            </div>
                                            <div class="col-12">
                                                <button type="submit" class="btn btn-primary">Save Profile</button>
                                            </div>
                                        </div>
                                    </form>
                                    {% if isAdminViewer %}
                                        <div class="mt-3 pt-3 border-top d-flex flex-wrap align-items-end gap-2">
                                            <form id="adminDeductPointsForm" class="d-flex align-items-end gap-2 mb-0">
                                                <input type="hidden" name="target_user_id" value="{{ targetUser.id }}">
                                                <div>
                                                    <label for="deductPointsInput" class="form-label mb-1">Points to deduct</label>
                                                    <input type="number" min="1" step="1" value="50" class="form-control" id="deductPointsInput" name="points" required>
                                                </div>
                                                <button type="submit" class="btn btn-warning">Deduct Points</button>
                                            </form>
                                            <form id="adminDeleteAccountForm" class="mb-0">
                                                <input type="hidden" name="target_user_id" value="{{ targetUser.id }}">
                                                <button type="submit" class="btn btn-danger">Delete Account</button>
                                            </form>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="card shadow-sm border-0">
                                    <div class="card-body p-4">
                                        <h3 class="h5 mb-3">Change Password</h3>
                                        <form id="profilePasswordForm" method="post" action="">
                                            <input type="hidden" name="target_user_id" value="{{ targetUser.id }}">
                                            <div class="mb-3">
                                                <label for="current_password" class="form-label">Current password</label>
                                                <input type="password" class="form-control" id="current_password" name="current_password" {{ requireCurrentPassword ? 'required' : '' }}>
                                                {% if not requireCurrentPassword %}
                                                    <div class="form-text">Admin override: current password is not required when editing another user.</div>
                                                {% endif %}
                                            </div>
                                            <div class="mb-3">
                                                <label for="new_password" class="form-label">New password</label>
                                                <input type="password" class="form-control" id="new_password" name="new_password" required>
                                                <div class="form-text">At least 8 characters, with upper/lowercase, a number, and a special character.</div>
                                            </div>
                                            <div class="mb-3">
                                                <label for="confirm_password" class="form-label">Confirm new password</label>
                                                <input type="password" class="form-control" id="confirm_password" name="confirm_password" required>
                                            </div>
                                            <button type="submit" class="btn btn-light w-100">Update Password</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="card shadow-sm border-0 mb-4">
                                <div class="card-body p-4">
                                    <h3 class="h5 mb-3">Account Info</h3>
                                    {% if isAdminViewer %}
                                        <form id="adminRoleForm" class="mb-3">
                                            <input type="hidden" name="target_user_id" value="{{ targetUser.id }}">
                                            <label for="adminRoleSelect" class="form-label">Role</label>
                                            <div class="d-flex gap-2">
                                                <select id="adminRoleSelect" name="is_admin" class="form-select">
                                                    <option value="0" {{ not targetUser.isAdmin ? 'selected' : '' }}>User</option>
                                                    <option value="1" {{ targetUser.isAdmin ? 'selected' : '' }}>Admin</option>
                                                </select>
                                                <button type="submit" class="btn btn-light">Update </button>
                                            </div>
                                        </form>
                                    {% endif %}
                                    <ul class="list-group list-group-flush">
                                        <li class="list-group-item px-0 d-flex justify-content-between"><span class="text-secondary">User ID</span><strong id="accountInfoId">{{ targetUser.id }}</strong></li>
                                        <li class="list-group-item px-0 d-flex justify-content-between"><span class="text-secondary">Role</span><strong id="accountInfoRole">{{ targetUser.isAdmin ? 'Admin' : 'User' }}</strong></li>
                                        <li class="list-group-item px-0 d-flex justify-content-between"><span class="text-secondary">Rating</span><strong id="accountInfoRating">{{ targetUser.rating }}</strong></li>
                                        <li class="list-group-item px-0 d-flex justify-content-between"><span class="text-secondary">Created</span><strong id="accountInfoCreatedAt">{{ targetUser.createdAt|date('Y-m-d H:i:s') }}</strong></li>
                                        <li class="list-group-item px-0 d-flex justify-content-between"><span class="text-secondary">Updated</span><strong id="accountInfoUpdatedAt">{{ targetUser.updatedAt ? targetUser.updatedAt|date('Y-m-d H:i:s') : '' }}</strong></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}
