{% extends 'base.html.twig' %}

{% block title %}Add Problem{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-lg-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h1 class="h3 mb-1">Add Problem</h1>
                                <p class="text-secondary mb-0">Admin-only page for creating a new problem and its test cases.</p>
                            </div>
                            <a href="{{ path('problems_index') }}" class="btn btn-outline-secondary">Back to problemset</a>
                        </div>

                        {% if error %}
                            <div class="alert alert-danger">{{ error }}</div>
                        {% endif %}

                        <form method="post" class="needs-validation" novalidate>
                            <div class="row g-3">
                                <div class="col-12 col-lg-8">
                                    <label for="title" class="form-label">Title</label>
                                    <input type="text" class="form-control" id="title" name="title" maxlength="200" required>
                                </div>
                                <div class="col-12 col-lg-4">
                                    <label for="category" class="form-label">Category</label>
                                    <input type="text" class="form-control" id="category" name="category" maxlength="300" value="General" required>
                                </div>
                                <div class="col-12">
                                    <label for="description" class="form-label">Description</label>
                                    <textarea class="form-control" id="description" name="description" rows="7" required></textarea>
                                </div>
                                <div class="col-6 col-lg-3">
                                    <label for="difficulty" class="form-label">Difficulty</label>
                                    <input type="number" class="form-control" id="difficulty" name="difficulty" min="1" value="900" required>
                                </div>
                                <div class="col-6 col-lg-3">
                                    <label for="time_limit_ms" class="form-label">Time limit (ms)</label>
                                    <input type="number" class="form-control" id="time_limit_ms" name="time_limit_ms" min="1" value="1000" required>
                                </div>
                                <div class="col-6 col-lg-3">
                                    <label for="memory_limit_mb" class="form-label">Memory limit (MB)</label>
                                    <input type="number" class="form-control" id="memory_limit_mb" name="memory_limit_mb" min="1" value="256" required>
                                </div>
                            </div>

                            <div class="mt-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h2 class="h5 mb-0">Test Cases</h2>
                                    <button type="button" class="btn btn-sm btn-outline-primary" id="addTestCaseButton">Add test case</button>
                                </div>

                                <div id="testCasesContainer" class="vstack gap-3">
                                    <div class="card border">
                                        <div class="card-body">
                                            <div class="row g-3 align-items-end">
                                                <div class="col-12 col-lg-5">
                                                    <label class="form-label">Input</label>
                                                    <textarea class="form-control" name="test_input[]" rows="4" required></textarea>
                                                </div>
                                                <div class="col-12 col-lg-5">
                                                    <label class="form-label">Expected output</label>
                                                    <textarea class="form-control" name="test_expected_output[]" rows="4" required></textarea>
                                                </div>
                                                <div class="col-12 col-lg-2">
                                                    <label class="form-label">Sample?</label>
                                                    <select class="form-select" name="test_is_sample[]">
                                                        <option value="1" selected>Yes</option>
                                                        <option value="0">No</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary px-4">Create Problem</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <template id="testCaseTemplate">
        <div class="card border">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-lg-5">
                        <label class="form-label">Input</label>
                        <textarea class="form-control" name="test_input[]" rows="4" required></textarea>
                    </div>
                    <div class="col-12 col-lg-5">
                        <label class="form-label">Expected output</label>
                        <textarea class="form-control" name="test_expected_output[]" rows="4" required></textarea>
                    </div>
                    <div class="col-12 col-lg-2">
                        <label class="form-label">Sample?</label>
                        <select class="form-select" name="test_is_sample[]">
                            <option value="1">Yes</option>
                            <option value="0" selected>No</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <script>
        (() => {
            const addButton = document.getElementById('addTestCaseButton');
            const container = document.getElementById('testCasesContainer');
            const template = document.getElementById('testCaseTemplate');
            if (!addButton || !container || !template) return;
            addButton.addEventListener('click', () => {
                container.insertAdjacentHTML('beforeend', template.innerHTML);
            });
        })();
    </script>
{% endblock %}