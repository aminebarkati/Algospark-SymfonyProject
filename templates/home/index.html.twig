{% extends 'base.html.twig' %}

{% block title %}AlgoSpark{% endblock %}

{% block body %}
    <main class="container py-5">
        <div class="row align-items-center g-4 mb-4">
            <div class="col-12 col-lg-7">
                <div class="p-4 p-md-5 rounded-4 shadow-sm bg-white border">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <object data="/assets/media/svg-components/code-slash.svg" type="image/svg+xml" width="56" height="56"></object>
                        <div>
                            <div class="text-uppercase text-secondary small fw-semibold">AlgoSpark</div>
                            <h1 class="display-6 mb-0">Solve problems, track progress, climb the board.</h1>
                        </div>
                    </div>
                    <p class="lead text-secondary mb-4">A clean competitive programming workspace with problems, submissions, favorites, and ratings in one place.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('problems_index') }}" class="btn btn-primary btn-lg">Problemset</a>
                        <a href="{{ path('leaderboard_index') }}" class="btn btn-light btn-lg">Leaderboard</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5">
                {% if app.user %}
                    <div class="p-4 rounded-4 shadow-sm bg-primary text-white h-100">
                        <div class="mb-4">
                            <div class="small text-uppercase opacity-75">Welcome back</div>
                            <h2 class="h3 mb-1">{{ app.user.userIdentifier }}</h2>
                            <p class="mb-0 opacity-75">Your latest activity and current platform stats.</p>
                        </div>
                        <div class="row g-3">
                            {% if userStats is defined and userStats is not null %}
                                <div class="col-6">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center">
                                        <div class="h5 mb-1">{{ userStats.rating }}</div>
                                        <small>Rating</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center">
                                        <div class="h6 mb-1">{{ userStats.submissions }}</div>
                                        <small>Submissions</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center mt-3">
                                        <div class="h6 mb-1">{{ userStats.solved }}</div>
                                        <small>Solved</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center mt-3">
                                        <div class="h6 mb-1">{{ userStats.favorites }}</div>
                                        <small>Favorites</small>
                                    </div>
                                </div>
                            {% else %}
                                <div class="col-4">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center">
                                        <div class="h4 mb-1">{{ problemCount }}</div>
                                        <small>Problems</small>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center">
                                        <div class="h4 mb-1">{{ submissionCount }}</div>
                                        <small>Submissions</small>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="rounded-3 bg-white bg-opacity-10 p-3 text-center">
                                        <div class="h4 mb-1">{{ userCount }}</div>
                                        <small>Users</small>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="p-4 rounded-4 shadow-sm bg-primary text-white h-100">
                        <div class="small text-uppercase opacity-75 mb-2">Get started</div>
                        <h2 class="h3">Start solving in minutes</h2>
                        <p class="opacity-75 mb-4">Create an account, pick a problem, and submit your solution. Track favorites, submissions, and rating as you go.</p>
                        <div class="mb-4">
                            <div class="d-flex gap-3 mb-3">
                                <div class="badge text-bg-light text-dark rounded-pill px-3 py-2">1. Sign up</div>
                                <div class="badge text-bg-light text-dark rounded-pill px-3 py-2">2. Solve</div>
                                <div class="badge text-bg-light text-dark rounded-pill px-3 py-2">3. Rank up</div>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-light" data-bs-toggle="modal" data-bs-target="#LogModal">Log In</button>
                            <button class="btn btn-primary border border-white" data-bs-toggle="modal" data-bs-target="#signmodal">Sign Up</button>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <div class="text-secondary small text-uppercase">Problems</div>
                        <div class="display-6 fw-bold text-info">{{ problemCount }}</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <div class="text-secondary small text-uppercase">Submissions</div>
                        <div class="display-6 fw-bold text-info">{{ submissionCount }}</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <div class="text-secondary small text-uppercase">Community</div>
                        <div class="display-6 fw-bold text-info">{{ userCount }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-primary text-white py-3">
                        <h2 class="h5 mb-0">Featured Problem</h2>
                    </div>
                    <div class="card-body p-4">
                        {% if featuredProblem %}
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge text-bg-info">{{ featuredProblem.category }}</span>
                                <span class="badge text-bg-secondary">AC: {{ featuredProblem.successCount }} / {{ featuredProblem.totalAttempts }}</span>
                            </div>
                            <h3 class="h4">{{ featuredProblem.title }}</h3>
                            {% set featuredDescription = featuredProblem.description|striptags %}
                            <p class="text-secondary mb-4">
                                {{ featuredDescription|length > 160 ? featuredDescription|slice(0, 160) ~ '...' : featuredDescription }}
                            </p>
                            <a href="{{ path('problems_show', {id: featuredProblem.id}) }}" class="btn btn-primary">Open Problem</a>
                        {% else %}
                            <p class="text-secondary mb-0">No problems available yet.</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-7">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-primary text-white py-3">
                        <h2 class="h5 mb-0">Recent Submissions</h2>
                    </div>
                    <div class="card-body p-0">
                        {% if recentSubmissions is not empty %}
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead>
                                        <tr>
                                            <th>Problem</th>
                                            <th>User</th>
                                            <th>Language</th>
                                            <th>Verdict</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for submission in recentSubmissions %}
                                            {% set verdict = submission.verdict %}
                                            <tr>
                                                <td><a href="{{ path('problems_show', {id: submission.problem.id}) }}" class="text-info">{{ submission.problem.title }}</a></td>
                                                <td><a href="{{ path('profile_show', {username: submission.user.username}) }}">{{ submission.user.username }}</a></td>
                                                <td>{{ submission.language.name }}</td>
                                                <td><span class="badge" style="background-color: {{ verdict ? verdict.colorCode : '#6c757d' }}">{{ verdict ? verdict.displayName : 'Pending' }}</span></td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="p-4 text-secondary">No submissions yet.</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
